-- bantLo Supabase Database Schema
-- Execute this block in your Supabase SQL Editor

CREATE EXTENSION IF NOT EXISTS "pgcrypto";

-- ==========================================
-- 1. Table Definitions
-- ==========================================

-- GROUPS
CREATE TABLE groups (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  name TEXT NOT NULL,
  created_by UUID REFERENCES auth.users(id) NOT NULL,
  currency VARCHAR(3) DEFAULT 'USD',
  updated_at TIMESTAMP WITH TIME ZONE DEFAULT timezone('utc', now())
);

-- GROUP MEMBERS
CREATE TABLE group_members (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  group_id UUID REFERENCES groups(id) ON DELETE CASCADE,
  user_id UUID REFERENCES auth.users(id) ON DELETE CASCADE,
  UNIQUE(group_id, user_id)
);

-- EXPENSES
CREATE TABLE expenses (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  group_id UUID REFERENCES groups(id) ON DELETE CASCADE,
  paid_by UUID REFERENCES auth.users(id) ON DELETE CASCADE,
  amount NUMERIC(10,2) NOT NULL,
  description VARCHAR(40) NOT NULL,
  notes TEXT,
  split_type SMALLINT NOT NULL CHECK (split_type IN (0, 1, 2)), -- 0=equal, 1=exact, 2=shares
  created_at TIMESTAMP WITH TIME ZONE DEFAULT timezone('utc', now())
);

-- EXPENSE SPLITS (Computed Owed Amounts)
CREATE TABLE expense_splits (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  expense_id UUID REFERENCES expenses(id) ON DELETE CASCADE,
  user_id UUID REFERENCES auth.users(id) ON DELETE CASCADE,
  amount_owed NUMERIC(10,2) NOT NULL
);

-- BALANCES (Computed continuous states per user per group)
CREATE TABLE balances (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  group_id UUID REFERENCES groups(id) ON DELETE CASCADE,
  user_id UUID REFERENCES auth.users(id) ON DELETE CASCADE,
  balance NUMERIC(10,2) NOT NULL DEFAULT 0.00, -- Positive means owed to them, Negative means they owe
  updated_at TIMESTAMP WITH TIME ZONE DEFAULT timezone('utc', now()),
  UNIQUE(group_id, user_id)
);

-- SETTLEMENTS (Repayments between users)
CREATE TABLE settlements (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  group_id UUID REFERENCES groups(id) ON DELETE CASCADE,
  from_user_id UUID REFERENCES auth.users(id) ON DELETE CASCADE,
  to_user_id UUID REFERENCES auth.users(id) ON DELETE CASCADE,
  amount NUMERIC(10,2) NOT NULL CHECK (amount > 0),
  created_at TIMESTAMP WITH TIME ZONE DEFAULT timezone('utc', now())
);


-- ==========================================
-- 2. Row Level Security Policies
-- ==========================================

ALTER TABLE groups ENABLE ROW LEVEL SECURITY;
ALTER TABLE group_members ENABLE ROW LEVEL SECURITY;
ALTER TABLE expenses ENABLE ROW LEVEL SECURITY;
ALTER TABLE expense_splits ENABLE ROW LEVEL SECURITY;
ALTER TABLE balances ENABLE ROW LEVEL SECURITY;
ALTER TABLE settlements ENABLE ROW LEVEL SECURITY;

-- Helper function: Is user a member of the group?
CREATE OR REPLACE FUNCTION is_group_member(check_group_id UUID)
RETURNS BOOLEAN AS $$
BEGIN
  RETURN EXISTS (
    SELECT 1 FROM group_members 
    WHERE group_members.group_id = check_group_id 
    AND group_members.user_id = auth.uid()
  );
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

-- GROUPS Policies
CREATE POLICY "Users can view groups they belong to" 
ON groups FOR SELECT 
USING (is_group_member(id) OR created_by = auth.uid());

CREATE POLICY "Users can insert groups" 
ON groups FOR INSERT 
WITH CHECK (auth.uid() = created_by);

CREATE POLICY "Users can update groups they belong to" 
ON groups FOR UPDATE 
USING (is_group_member(id));

-- GROUP MEMBERS Policies
CREATE POLICY "Users can view members of their groups" 
ON group_members FOR SELECT 
USING (is_group_member(group_id) OR user_id = auth.uid());

CREATE POLICY "Users can add members to groups" 
ON group_members FOR INSERT 
WITH CHECK (is_group_member(group_id) OR (SELECT created_by FROM groups WHERE id = group_id) = auth.uid());

CREATE POLICY "Users can remove members from their groups" 
ON group_members FOR DELETE 
USING (is_group_member(group_id));

-- EXPENSES Policies
CREATE POLICY "Users can view expenses of their groups" 
ON expenses FOR SELECT USING (is_group_member(group_id));

CREATE POLICY "Users can insert expenses in their groups" 
ON expenses FOR INSERT WITH CHECK (is_group_member(group_id));

CREATE POLICY "Users can update expenses in their groups" 
ON expenses FOR UPDATE USING (is_group_member(group_id));

CREATE POLICY "Users can delete expenses in their groups" 
ON expenses FOR DELETE USING (is_group_member(group_id));

-- EXPENSE SPLITS Policies
CREATE POLICY "Users can view splits of their group expenses" 
ON expense_splits FOR SELECT USING (
  EXISTS (SELECT 1 FROM expenses WHERE expenses.id = expense_id AND is_group_member(expenses.group_id))
);

CREATE POLICY "Users can insert splits in their group expenses" 
ON expense_splits FOR INSERT WITH CHECK (
  EXISTS (SELECT 1 FROM expenses WHERE expenses.id = expense_id AND is_group_member(expenses.group_id))
);

-- BALANCES Policies
CREATE POLICY "Users can view balances of their groups" 
ON balances FOR SELECT USING (is_group_member(group_id));

-- Notes: Balances should ideally only be mutated by PostgreSQL triggers for strict security,
-- but allowing SELECT/UPDATE purely for this schema if we're doing frontend computed inserts.
CREATE POLICY "Users can manage balances in their groups" 
ON balances FOR ALL USING (is_group_member(group_id));

-- SETTLEMENTS Policies
CREATE POLICY "Users can view settlements of their groups" 
ON settlements FOR SELECT USING (is_group_member(group_id));

CREATE POLICY "Users can insert settlements in their groups" 
ON settlements FOR INSERT WITH CHECK (is_group_member(group_id));

